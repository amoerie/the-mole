{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "CSharpier",
      "command": "dotnet",
      "args": ["csharpier", "format", "${staged}"],
      "include": ["**/*.cs"]
    },
    {
      "name": "Prettier",
      "command": "npx",
      "args": ["prettier", "--ignore-unknown", "--write", "${staged}"],
      "pathMode": "absolute",
      "include": [
        "client/**/*.ts",
        "client/**/*.tsx",
        "client/**/*.js",
        "client/**/*.json",
        "client/**/*.css"
      ]
    }
  ]
}
