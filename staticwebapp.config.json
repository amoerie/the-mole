{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/images/*", "/*.ico", "/*.png", "/*.svg"]
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/me",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/games/by-invite/*",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/.auth/login/google",
      "statusCode": 404
    },
    {
      "route": "/.auth/login/facebook",
      "statusCode": 404
    },
    {
      "route": "/.auth/login/twitter",
      "statusCode": 404
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/github"
    }
  },
  "platform": {
    "apiRuntime": "dotnet-isolated:8.0"
  }
}
